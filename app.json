{
  "expo": {
    "name": "TREND Coffee",
    "slug": "trend-coffee-app",
    "version": "2.1.3",
    "orientation": "portrait",
    "icon": "./assets/images/trend/logo-icon-padded.png",
    "scheme": "trend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Ứng dụng cần truy cập thư viện ảnh để lưu ảnh.",
        "NSPhotoLibraryAddUsageDescription": "Ứng dụng cần quyền lưu ảnh vào thư viện.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.trendcoffee.order"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/trend/logo-icon-padded.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "package": "com.trendcoffee.order"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/trend/logo-icon-padded.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Cho phép ứng dụng truy cập thư viện ảnh để lưu ảnh.",
          "savePhotosPermission": "Cho phép ứng dụng lưu ảnh vào thư viện.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "expo-build-properties",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/trend/logo-icon-padded.png",
          "color": "#F7A737",
          "sounds": [
            "./assets/sound/notification.mp3"
          ],
          "defaultChannel": "default"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "jsEngine": "hermes",
    "extra": {
      "router": {}
    }
  }
}
