{
  "cli": {
    "version": ">= 18.0.6",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_BASE_API_URL": "@env:EXPO_PUBLIC_BASE_API_URL",
        "EXPO_PUBLIC_FILE_URL": "@env:EXPO_PUBLIC_FILE_URL",
        "EXPO_PUBLIC_GOOGLE_MAP_API_KEY": "@env:EXPO_PUBLIC_GOOGLE_MAP_API_KEY",
        "EXPO_PUBLIC_ORDER_EXPIRATION_TIME_SECONDS": "@env:EXPO_PUBLIC_ORDER_EXPIRATION_TIME_SECONDS",
        "EXPO_PUBLIC_TREND_PHONE": "@env:EXPO_PUBLIC_TREND_PHONE",
        "EXPO_PUBLIC_REGISTRATION_PHONE": "@env:EXPO_PUBLIC_REGISTRATION_PHONE",
        "EXPO_PUBLIC_TREND_EMAIL": "@env:EXPO_PUBLIC_TREND_EMAIL",
        "EXPO_PUBLIC_TREND_FANPAGE_URL": "@env:EXPO_PUBLIC_TREND_FANPAGE_URL",
        "EXPO_PUBLIC_TREND_YOUTUBE_VIDEO_ID": "@env:EXPO_PUBLIC_TREND_YOUTUBE_VIDEO_ID",
        "EXPO_PUBLIC_FIREBASE_API_KEY": "@env:EXPO_PUBLIC_FIREBASE_API_KEY",
        "EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN": "@env:EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN",
        "EXPO_PUBLIC_FIREBASE_PROJECT_ID": "@env:EXPO_PUBLIC_FIREBASE_PROJECT_ID",
        "EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET": "@env:EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET",
        "EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID": "@env:EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID",
        "EXPO_PUBLIC_FIREBASE_APP_ID": "@env:EXPO_PUBLIC_FIREBASE_APP_ID",
        "EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID": "@env:EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
